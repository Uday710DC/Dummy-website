<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Decentrialz — Wireframe v1 (Phase 2 Homepage)</title>
<style>
  /* =========================================
     WIREFRAME TOKENS — strictly grayscale +
     a single accent for primary CTAs only.
     ========================================= */
  :root {
    --bg:           #EDEEF0;
    --paper:        #FFFFFF;
    --line:         #C4C7CC;
    --line-strong:  #8A8E94;
    --line-soft:    #DCDEE2;
    --fill-1:       #F4F5F7;
    --fill-2:       #E4E6EA;
    --fill-3:       #D2D5DA;
    --ink:          #3A3D42;
    --ink-soft:     #6A6E74;
    --ink-faint:    #9CA0A6;
    --accent:       #287ABD;       /* brand primary, used VERY sparingly */
    --accent-soft:  #DCE7F2;
    --annotate:     #B85C00;       /* wireframe annotation color */
    --annotate-soft:#FFF1DD;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Courier New', ui-monospace, monospace;
    background: var(--bg);
    color: var(--ink);
    font-size: 13px;
    line-height: 1.5;
    padding: 32px 16px 80px;
  }

  /* ---------- WIREFRAME WRAPPER ---------- */
  .wf-meta {
    max-width: 1180px;
    margin: 0 auto 20px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 8px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .wf-meta h1 {
    font-family: 'Georgia', serif;
    font-weight: 400;
    font-size: 22px;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .wf-meta .sub {
    font-size: 11px;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .wf-meta .stamp {
    border: 1.5px dashed var(--annotate);
    color: var(--annotate);
    background: var(--annotate-soft);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 6px 14px;
    text-transform: uppercase;
    transform: rotate(-1deg);
  }

  .browser {
    max-width: 1180px;
    margin: 0 auto;
    background: var(--paper);
    border: 1.5px solid var(--line-strong);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.10), 0 2px 6px rgba(0,0,0,0.06);
  }
  .browser-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--fill-2);
    border-bottom: 1px solid var(--line);
  }
  .browser-bar .dots { display: flex; gap: 6px; }
  .browser-bar .dot {
    width: 11px; height: 11px;
    border-radius: 999px;
    background: var(--fill-3);
    border: 1px solid var(--line);
  }
  .browser-bar .url {
    flex: 1;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 11px;
    color: var(--ink-soft);
  }

  /* ---------- SECTION SHELL ---------- */
  .section {
    position: relative;
    border-bottom: 1px dashed var(--line);
    padding: 0;
  }
  .section:last-child { border-bottom: none; }

  .section-tag {
    position: absolute;
    top: 14px;
    left: -76px;
    width: 64px;
    text-align: right;
    font-size: 10px;
    font-weight: 700;
    color: var(--annotate);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
  }
  .section-tag .num {
    display: block;
    font-size: 22px;
    font-family: 'Georgia', serif;
    color: var(--annotate);
    font-weight: 400;
    margin-bottom: 2px;
  }
  @media (max-width: 1320px) {
    .section-tag {
      position: relative; left: 0; top: 0;
      width: auto; text-align: left;
      padding: 12px 24px 0;
      display: flex; align-items: baseline; gap: 10px;
    }
    .section-tag .num {
      display: inline; font-size: 16px; margin: 0;
    }
  }

  .container {
    padding: 24px 32px;
  }

  /* ---------- WIREFRAME PRIMITIVES ---------- */
  .ph-line {
    height: 8px;
    background: var(--fill-2);
    border-radius: 2px;
    margin-bottom: 6px;
  }
  .ph-line.short { width: 40%; }
  .ph-line.mid   { width: 65%; }
  .ph-line.long  { width: 90%; }
  .ph-line.full  { width: 100%; }
  .ph-line.dark  { background: var(--fill-3); }

  .ph-heading {
    height: 18px;
    background: var(--fill-3);
    border-radius: 3px;
    margin-bottom: 10px;
  }
  .ph-heading.lg { height: 28px; }
  .ph-heading.xl { height: 40px; }

  /* image / illustration placeholder w/ diagonal lines */
  .ph-img {
    background: var(--fill-1);
    border: 1.5px dashed var(--line);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .ph-img::before, .ph-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom right, transparent calc(50% - 0.5px), var(--line) 50%, transparent calc(50% + 0.5px));
    opacity: 0.5;
  }
  .ph-img::after {
    background: linear-gradient(to top right, transparent calc(50% - 0.5px), var(--line) 50%, transparent calc(50% + 0.5px));
  }
  .ph-img > span {
    position: relative;
    z-index: 2;
    background: var(--paper);
    padding: 2px 8px;
    border: 1px solid var(--line);
    border-radius: 2px;
  }

  /* button shapes */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1.5px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    padding: 8px 16px;
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 4px;
    cursor: pointer;
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .btn.ghost {
    border-style: dashed;
    border-color: var(--line-strong);
    color: var(--ink-soft);
  }
  .btn.lg { padding: 12px 22px; font-size: 12px; }
  .btn.sm { padding: 5px 10px; font-size: 10px; }

  /* tag / badge */
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--line);
    background: var(--fill-1);
    padding: 3px 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    color: var(--ink-soft);
  }
  .tag.live { border-color: var(--ink); color: var(--ink); background: var(--paper); }

  /* annotation callouts */
  .annotate {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    color: var(--annotate);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--annotate-soft);
    padding: 2px 8px;
    border: 1px dashed var(--annotate);
    border-radius: 3px;
  }
  .note {
    font-size: 10px;
    color: var(--annotate);
    font-style: italic;
    border-left: 2px solid var(--annotate);
    padding-left: 8px;
    margin: 6px 0;
    background: var(--annotate-soft);
    padding: 4px 8px;
    border-radius: 0 3px 3px 0;
  }

  /* generic input */
  .input {
    border: 1.5px solid var(--line);
    background: var(--paper);
    border-radius: 4px;
    padding: 10px 12px;
    font-family: inherit;
    font-size: 11px;
    color: var(--ink-faint);
    width: 100%;
  }
  .input.search::before {
    content: '⌕';
    margin-right: 8px;
  }

  /* layout helpers */
  .row { display: flex; gap: 16px; align-items: center; }
  .row.between { justify-content: space-between; }
  .row.wrap { flex-wrap: wrap; }
  .stack > * + * { margin-top: 8px; }

  /* =========================================
     SECTION-SPECIFIC STYLES
     ========================================= */

  /* 1. Utility bar */
  .utility-bar {
    background: var(--ink);
    color: #fff;
    font-size: 11px;
    padding: 6px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .utility-bar .left, .utility-bar .right { display: flex; gap: 16px; align-items: center; }
  .utility-bar .pill {
    border: 1px solid rgba(255,255,255,0.4);
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  /* 2. Nav bar */
  .nav {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    padding: 16px 32px;
    border-bottom: 1px solid var(--line-soft);
    gap: 24px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Georgia', serif;
    font-size: 16px;
    color: var(--ink);
  }
  .nav-logo .mark {
    width: 28px; height: 28px;
    border: 2px solid var(--ink);
    background: var(--fill-2);
    border-radius: 4px;
  }
  .nav-links {
    display: flex;
    gap: 22px;
    justify-content: center;
  }
  .nav-link {
    font-size: 11px;
    color: var(--ink);
    border-bottom: 2px solid transparent;
    padding: 4px 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .nav-link.active { border-bottom-color: var(--ink); }
  .nav-cta { display: flex; gap: 8px; }

  /* 3. Hero */
  .hero {
    padding: 48px 32px 32px;
    background: linear-gradient(180deg, var(--fill-1) 0%, var(--paper) 100%);
  }
  .audience-toggle {
    display: inline-flex;
    border: 1.5px solid var(--line-strong);
    border-radius: 999px;
    padding: 4px;
    background: var(--paper);
    margin-bottom: 24px;
  }
  .audience-toggle .opt {
    padding: 6px 16px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 999px;
    color: var(--ink-soft);
  }
  .audience-toggle .opt.active {
    background: var(--ink);
    color: #fff;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .hero h2.mock {
    font-family: 'Georgia', serif;
    font-size: 32px;
    line-height: 1.2;
    margin: 8px 0 16px;
    color: var(--ink);
    font-weight: 400;
  }
  .trust-bullets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 16px;
    margin: 16px 0 20px;
    list-style: none;
    padding: 0;
  }
  .trust-bullets li {
    font-size: 11px;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .trust-bullets li::before {
    content: '✓';
    color: var(--ink);
    font-weight: 700;
    background: var(--fill-2);
    width: 14px; height: 14px;
    border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 9px;
  }
  .hero-cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
  .microcopy {
    font-size: 10px;
    color: var(--ink-faint);
    font-style: italic;
  }

  /* 4. Stats strip */
  .stats {
    background: var(--accent-soft);
    padding: 28px 32px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }
  .stat .num {
    font-family: 'Georgia', serif;
    font-size: 22px;
    color: var(--ink);
    font-weight: 700;
  }
  .stat .label {
    font-size: 11px;
    color: var(--ink);
    font-weight: 700;
    margin-top: 2px;
  }
  .stat .sub {
    font-size: 10px;
    color: var(--ink-soft);
    margin-top: 2px;
  }

  /* 5. Conditions */
  .conditions { padding: 48px 32px; }
  .section-header { text-align: center; margin-bottom: 28px; }
  .section-header h3 {
    font-family: 'Georgia', serif;
    font-weight: 400;
    font-size: 22px;
    margin: 0 0 6px;
    color: var(--ink);
  }
  .conditions .search-wrap {
    max-width: 540px;
    margin: 0 auto 24px;
    position: relative;
  }
  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    max-width: 880px;
    margin: 0 auto;
  }
  .cond-tile {
    border: 1.5px solid var(--line);
    border-radius: 6px;
    padding: 18px 14px;
    background: var(--paper);
    text-align: center;
  }
  .cond-tile.featured {
    border-color: var(--ink);
    background: var(--fill-1);
    grid-row: span 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .cond-tile .icon {
    width: 28px; height: 28px;
    margin: 0 auto 8px;
    border: 1.5px solid var(--line-strong);
    background: var(--fill-2);
    border-radius: 999px;
  }
  .cond-tile .name { font-size: 12px; font-weight: 700; color: var(--ink); }
  .cond-tile .count { font-size: 10px; color: var(--ink-soft); margin-top: 3px; }

  /* 6. How it works */
  .how { padding: 48px 32px; background: var(--fill-1); }
  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 980px;
    margin: 0 auto;
  }
  .how-step {
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 6px;
    padding: 24px;
    text-align: center;
    position: relative;
  }
  .how-step .step-num {
    width: 36px; height: 36px;
    border-radius: 999px;
    background: var(--ink);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Georgia', serif;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .how-step h4 {
    font-family: 'Georgia', serif;
    font-weight: 400;
    font-size: 16px;
    margin: 0 0 6px;
    color: var(--ink);
  }
  .how-step .desc { font-size: 11px; color: var(--ink-soft); }
  .how-step .timer {
    margin-top: 10px;
    display: inline-block;
    font-size: 10px;
    color: var(--ink);
    background: var(--fill-2);
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid var(--line);
  }
  .how-cta { text-align: center; margin-top: 24px; }

  /* 7. Human support */
  .support { padding: 48px 32px; }
  .support-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 980px;
    margin: 0 auto;
    align-items: stretch;
  }
  .support-form {
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 6px;
    padding: 24px;
  }
  .support-value {
    list-style: none;
    padding: 0;
    margin: 14px 0 18px;
  }
  .support-value li {
    font-size: 11px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--line-soft);
    color: var(--ink);
  }
  .contact-row {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  /* 8. Location */
  .location {
    padding: 48px 32px;
    background: var(--fill-1);
  }
  .location-card {
    max-width: 760px;
    margin: 0 auto;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 6px;
    padding: 28px;
  }
  .location-input-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: center;
    margin-top: 14px;
  }
  .location-input-row .or {
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }
  .map-strip {
    margin-top: 18px;
    height: 80px;
    border: 1.5px dashed var(--line);
    border-radius: 4px;
    background:
      repeating-linear-gradient(0deg, var(--fill-1) 0 19px, var(--line-soft) 19px 20px),
      repeating-linear-gradient(90deg, var(--fill-1) 0 19px, var(--line-soft) 19px 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* 9. Why */
  .why { padding: 48px 32px; }
  .why-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 32px;
    max-width: 980px;
    margin: 0 auto;
    align-items: center;
  }
  .why-list {
    list-style: none;
    padding: 0;
    margin: 16px 0 24px;
  }
  .why-list li {
    padding: 10px 0;
    border-bottom: 1px dashed var(--line-soft);
    font-size: 12px;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .why-list li::before {
    content: '✓';
    width: 18px; height: 18px;
    border-radius: 999px;
    background: var(--ink);
    color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* 10. Social proof */
  .proof {
    padding: 48px 32px;
    background: var(--ink);
    color: #fff;
  }
  .proof-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 880px;
    margin: 0 auto 24px;
    text-align: center;
  }
  .proof .num {
    font-family: 'Georgia', serif;
    font-size: 32px;
    font-weight: 700;
  }
  .proof .label {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    margin-top: 4px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .testimonial {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 16px;
    color: rgba(255,255,255,0.9);
    border-top: 1px solid rgba(255,255,255,0.2);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding: 18px 0;
  }
  .testimonial::before, .testimonial::after { content: '"'; color: rgba(255,255,255,0.5); }

  /* 11. Blog */
  .blog { padding: 48px 32px; }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 980px;
    margin: 0 auto;
  }
  .blog-card {
    border: 1.5px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    background: var(--paper);
  }
  .blog-card .ph-img {
    height: 120px;
    border: none;
    border-bottom: 1.5px dashed var(--line);
  }
  .blog-card .body { padding: 14px; }
  .blog-card h5 {
    font-family: 'Georgia', serif;
    font-weight: 400;
    font-size: 14px;
    margin: 0 0 8px;
    color: var(--ink);
    line-height: 1.3;
  }
  .blog-card .meta { font-size: 10px; color: var(--ink-faint); }
  .inline-cta {
    text-align: center;
    margin-top: 24px;
    padding: 16px;
    border: 1.5px dashed var(--ink);
    border-radius: 4px;
    background: var(--fill-1);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* 12. Email capture */
  .email-cap {
    padding: 40px 32px;
    background: var(--fill-1);
  }
  .email-cap-card {
    max-width: 720px;
    margin: 0 auto;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 6px;
    padding: 28px;
    text-align: center;
  }
  .email-form {
    display: grid;
    grid-template-columns: 1.5fr 1fr auto;
    gap: 8px;
    margin-top: 16px;
  }

  /* 13. FAQ */
  .faq { padding: 48px 32px; }
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
  }
  .faq-item {
    border: 1.5px solid var(--line);
    border-radius: 4px;
    padding: 14px 18px;
    margin-bottom: 8px;
    background: var(--paper);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }
  .faq-item.open {
    background: var(--fill-1);
    border-color: var(--ink);
  }
  .faq-q {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
  }
  .faq-a {
    font-size: 11px;
    color: var(--ink-soft);
    margin-top: 8px;
    line-height: 1.5;
  }
  .faq-icon {
    font-size: 14px;
    color: var(--ink-soft);
    flex-shrink: 0;
  }
  .faq-cta { text-align: center; margin-top: 24px; }

  /* 14. Footer */
  .footer {
    background: var(--ink);
    color: rgba(255,255,255,0.85);
    padding: 40px 32px 24px;
  }
  .footer-grid {
    display: grid;
